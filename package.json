{
  "name": "@fellow99/opencode-status-sync",
  "version": "0.3.1",
  "description": "OpenCode plugin that syncs AI status to an external service via configurable HTTP mappings",
  "private": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fellow99/opencode-status-sync.git"
  },
  "author": "fellow99",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/fellow99/opencode-status-sync/issues"
  },
  "homepage": "https://github.com/fellow99/opencode-status-sync#readme",
  "keywords": [
    "opencode",
    "opencode-plugin",
    "status-sync",
    "config-driven"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./server": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./tui": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsc",
    "prepublishOnly": "bun run typecheck && bun run build"
  },
  "engines": {
    "bun": ">=1.0.0"
  },
  "devDependencies": {
    "@opencode-ai/plugin": "^1.17.12",
    "@types/bun": "^1.3.14",
    "typescript": "^5.7.0"
  }
}
