{
  "name": "opencode-status-sync",
  "version": "0.2.0",
  "description": "OpenCode plugin that syncs AI status to an external service via configurable HTTP mappings",
  "type": "module",
  "main": ".opencode/plugins/opencode-status-sync.ts",
  "types": ".opencode/plugins/opencode-status-sync.ts",
  "exports": {
    ".": {
      "types": "./.opencode/plugins/opencode-status-sync.ts",
      "import": "./.opencode/plugins/opencode-status-sync.ts",
      "default": "./.opencode/plugins/opencode-status-sync.ts"
    }
  },
  "scripts": {
    "typecheck": "bun x tsc --noEmit",
    "prepublishOnly": "bun run typecheck"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fellow99/opencode-status-sync.git"
  },
  "author": "fellow99",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/fellow99/opencode-status-sync/issues"
  },
  "homepage": "https://github.com/fellow99/opencode-status-sync#readme",
  "keywords": [
    "opencode",
    "opencode-plugin",
    "status-sync",
    "config-driven"
  ],
  "engines": {
    "bun": ">=1.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@opencode-ai/plugin": "^1.17.12",
    "@types/bun": "^1.3.14",
    "typescript": "^5.7.0"
  }
}
